# =============================================================================
# .gitignore – Agora Automation Assignment
# =============================================================================

# Python bytecode
__pycache__/
*.py[codz]

# UV virtual environment
# Note: uv.lock IS committed for reproducible installs – do NOT ignore it.
.venv/
.python-version

# Secrets – NEVER commit the real .env (commit .env.example instead)
.env

# Pytest
.pytest_cache/
.cache

# Coverage
htmlcov/
.coverage
.coverage.*
coverage.xml

# Allure
allure-results/
allure-report/

# Playwright
playwright/.auth/

# Logs
*.log

# IDEs
.idea/
.vscode/
